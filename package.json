{
  "name": "phishguard",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --parallel --filter @phishguard/backend --filter @phishguard/frontend dev",
    "dev:backend": "pnpm --filter @phishguard/backend dev",
    "dev:frontend": "pnpm --filter @phishguard/frontend dev",
    "build": "pnpm --filter @phishguard/shared build && pnpm --filter @phishguard/backend build && pnpm --filter @phishguard/frontend build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format"
  }
}
